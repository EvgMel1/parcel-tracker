{
  "version": 2,
  "buildCommand": "npx expo export --platform web",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.js": {
      "runtime": "@vercel/node@2.0.0"
    }
  },
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "/api/:match*"
    },
    {
      "source": "/_expo/:match*",
      "destination": "/dist/_expo/:match*"
    },
    {
      "source": "/assets/:match*",
      "destination": "/dist/assets/:match*"
    },
    {
      "source": "/(.*)",
      "destination": "/dist/index.html"
    }
  ]
}
